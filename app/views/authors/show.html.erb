<h1><%= @author.name %></h1>
<p class="text-muted">Nationality: <%= @author.nationality %></p>
<p><%= @author.bio %></p>

<hr>

<h3>Books by <%= @author.name %></h3>

<!-- Feature 5.2 - ERB Conditional -->
<% if @books.empty? %>
  <p class="text-muted">No books found for this author.</p>
<% else %>
  <ul class="list-group">
    <% @books.each do |book| %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <%= link_to book.title, book_path(book) %>
        <span class="badge bg-secondary"><%= book.genre %></span>
      </li>
    <% end %>
  </ul>
<% end %>

<br>
<%= link_to "← Back to All Authors", authors_path, class: "btn btn-secondary" %>