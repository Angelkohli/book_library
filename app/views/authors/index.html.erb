<h1 class="mb-4"> All Authors</h1>
<p class="text-muted">Total: <%= @authors.count %> authors</p>

<div class="row">
  <% @authors.each do |author| %>
    <div class="col-md-4 mb-3">
      <div class="card h-100">
        <div class="card-body">
          <h2 class="card-title"><%= author.name %></h2>
          <p class="text-muted"><small><%= author.nationality %></small></p>
          <%= link_to "View Author →", author_path(author), class: "btn btn-sm btn-outline-primary" %>
        </div>
      </div>
    </div>
  <% end %>
</div>