<h1 class="mb-4"> All Books</h1>

<!-- 4.1 -->
<div class="row mb-4">
  <div class="col-md-6">
    <%= form_with url: books_path, method: :get, local: true do |f| %>
      <div class="input-group">
        <%= f.text_field :search,
            value: params[:search],
            placeholder: "Search by title or genre...",
            class: "form-control" %>
        <%= f.submit "Search", class: "btn btn-primary" %>
        <%= link_to "Clear", books_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>

<!--  5.2 - -->
<% if @books.empty? %>
  <div class="alert alert-warning">
    No books found matching your search. <br>
    <%= link_to "View all books", books_path %>
  </div>
<% else %>
  <p class="text-muted">Showing <%= @books.count %> books</p>

  <table class="table table-striped table-hover">
    <thead class="table-dark">
      <tr>
        <th>Title</th>
        <th>Genre</th>
        <th>Year</th>
        <th>Author</th>
        <th>Details</th>
      </tr>
    </thead>
    <tbody>
      <% @books.each do |book| %>
        <tr>
          <td><strong><%= book.title %></strong></td>
          <td><span class="badge bg-secondary"><%= book.genre %></span></td>
          <td><%= book.published_year %></td>
          <td><%= book.author&.name %></td>
          <td><%= link_to "View →", book_path(book), class: "btn btn-sm btn-outline-primary" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>