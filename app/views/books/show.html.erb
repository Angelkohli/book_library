<div class="row">
  <div class="col-md-8">
    <h1 class="mb-1"><%= @book.title %></h1>
    <span class="badge bg-primary mb-3"><%= @book.genre %></span>

    <table class="table">
      <tr>
        <th>Published Year</th>
        <td><%= @book.published_year %></td>
      </tr>
      <tr>
        <th>Description</th>
        <td><%= @book.description %></td>
      </tr>
    </table>
  </div>

  <div class="col-md-4">
    <div class="card">
      <div class="card-header bg-dark text-white">
        <strong>About the Author</strong>
      </div>
      <div class="card-body">
        <% if @author.present? %>
          <h5><%= @author.name %></h5>
          <p class="text-muted"><small>Nationality: <%= @author.nationality %></small></p>
          <p><%= @author.bio %></p>
          <%= link_to "See all books by #{@author.name}", author_path(@author), class: "btn btn-sm btn-outline-secondary" %>
        <% else %>
          <p>No author information available.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<br>
<%= link_to "← Back to All Books", books_path, class: "btn btn-secondary" %>